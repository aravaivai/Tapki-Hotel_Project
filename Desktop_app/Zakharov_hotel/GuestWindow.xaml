<Window x:Class="Zakharov_hotel.GuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кабинет гостя" Height="600" Width="900" WindowStartupLocation="CenterScreen" Background="{StaticResource BaseColor}">
    <DockPanel Margin="15" Background="{StaticResource BaseColor}">
        <TextBlock x:Name="lblHello" DockPanel.Dock="Top" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Background="{StaticResource BaseColor}"/>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Text="Дата заезда:" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpStart" Width="150" Margin="0,5,0,10" Background="{StaticResource BaseColor}"/>

                <TextBlock Text="Дата выезда:" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpEnd" Width="150" Margin="0,5,0,10"/>

                <Button Content="Найти свободные" Click="BtnFindFree_Click" Height="30"  Margin="0,10,0,0"/>
            </StackPanel>

            <GroupBox Header="Дополнительные услуги (выберите до 3-х)" Grid.Column="1" Margin="20,0,0,0">
                <ListBox x:Name="lstServices" SelectionMode="Multiple" DisplayMemberPath="DisplayInfo" SelectedValuePath="ServiceID" Background="{StaticResource BaseColor}"/>
            </GroupBox>
        </Grid>

        <GroupBox Header="Мои бронирования" DockPanel.Dock="Bottom" Height="180">
            <Grid>
                <DataGrid x:Name="dgMyBook" IsReadOnly="True" AutoGenerateColumns="True" Margin="5"/>
                <Button Content="Отменить бронь" Click="BtnCancel_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Width="120"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Доступные номера">
            <Grid>
                <DataGrid x:Name="dgRooms" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Номер" Binding="{Binding roomname}"/>
                        <DataGridTextColumn Header="Вместимость" Binding="{Binding capacity}"/>
                        <DataGridTextColumn Header="Цена за сутки" Binding="{Binding price}"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Content="Забронировать" Click="BtnBook_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Width="150" Height="35" FontWeight="Bold"/>
            </Grid>
        </GroupBox>
    </DockPanel>
</Window>