<Window x:Class="Zakharov_hotel.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель Администратора" Height="629" Width="1000" Background="{StaticResource BaseColor}"
        ScrollViewer.CanContentScroll="True"
        ScrollViewer.VerticalScrollBarVisibility="Auto">
    <Grid>
        <TabControl>
            <TabItem Header="Персонал">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="dgStaff" AutoGenerateColumns="True" SelectionChanged="DgStaff_SelectionChanged" IsReadOnly="True" Margin="5"/>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="ФИО сотрудника" FontWeight="Bold"/>
                        <TextBox x:Name="editName" Margin="0,5"/>
                        <TextBlock Text="Должность" Margin="0,5,0,0"/>
                        <ComboBox x:Name="cmbPositions" 
                            DisplayMemberPath="Наименование должности" 
                            SelectedValuePath="Код должности" 
                            Margin="0,5"/>
                        <TextBlock Text="Возраст"/>
                        <TextBox x:Name="editAge" Margin="0,5"/>
                        <TextBlock Text="Пол"/>
                        <TextBox x:Name="editGender" Margin="0,5"/>
                        <TextBlock Text="Адрес"/>
                        <TextBox x:Name="editAddress" Margin="0,5"/>
                        <TextBlock Text="Телефон"/>
                        <TextBox x:Name="editPhone" Margin="0,5"/>
                        <TextBlock Text="Паспортные данные"/>
                        <TextBox x:Name="editPassport" Margin="0,5"/>
                        <TextBlock Text="Премия"/>
                        <TextBox x:Name="editBonus" Margin="0,5"/>

                        <Button Content="Добавить нового" Click="BtnAdd_Click" Margin="0,10,0,5"/>
                        <Button Content="Сохранить изменения" Click="BtnSave_Click" Margin="0,0,0,5" />
                        <Button Content="Уволить (Удалить)" Click="BtnDelete_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Должности">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="dgPositions" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionChanged="dgPositions_SelectionChanged" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding PositionID}" Width="40"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="150"/>
                            <DataGridTextColumn Header="Оклад" Binding="{Binding Salary}" Width="80"/>
                            <DataGridTextColumn Header="Обязанности" Binding="{Binding Duties}" Width="*"/>
                            <DataGridTextColumn Header="Требования" Binding="{Binding Requirements}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ScrollViewer Grid.Column="1">
                        <StackPanel Margin="10">
                            <TextBlock Text="Название должности:" FontWeight="Bold"/>
                            <TextBox x:Name="txtPosTitle" Margin="0,5,0,10"/>

                            <TextBlock Text="Оклад (руб):" FontWeight="Bold"/>
                            <TextBox x:Name="txtPosSalary" Margin="0,5,0,10"/>

                            <TextBlock Text="Обязанности:" FontWeight="Bold"/>
                            <TextBox x:Name="txtPosDuties" Margin="0,5,0,10" Height="80" 
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Text="Требования:" FontWeight="Bold"/>
                            <TextBox x:Name="txtPosRequirements" Margin="0,5,0,10" Height="80" 
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                            <UniformGrid Columns="2">
                                <Button Content="Добавить новую" Click="AddPosition_Click" Margin="0,5,5,5" Height="30"/>
                                <Button Content="Сохранить изменения" Click="SavePosition_Click" Margin="5,5,0,5" Height="30"/>
                            </UniformGrid>
                            <Button Content="Удалить должность" Click="DeletePosition_Click" Margin="0,10,0,5" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Все бронирования">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgAllClients" AutoGenerateColumns="True" IsReadOnly="True" Grid.Row="0"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                        <Button Content="Удалить бронь" Click="BtnDeleteBooking_Click" Width="150" Height="30" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Управление номерами">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="dgRoomsAdmin" AutoGenerateColumns="True" IsReadOnly="True" SelectionChanged="DgRoomsAdmin_SelectionChanged" Margin="5"/>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Название номера" FontWeight="Bold"/>
                        <TextBox x:Name="txtRoomName" Margin="0,5"/>

                        <TextBlock Text="Вместимость (чел)"/>
                        <TextBox x:Name="txtRoomCap" Margin="0,5"/>

                        <TextBlock Text="Цена (руб)"/>
                        <TextBox x:Name="txtRoomPrice" Margin="0,5"/>

                        <Label Content="Ответственный:"/>
                        <ComboBox x:Name="cmbRoomEmployee" Width="200" DisplayMemberPath="fullname" SelectedValuePath="employeeid"/>


                        <Button Content="Добавить номер" Click="BtnAddRoom_Click" Margin="0,15,0,5"/>
                        <Button Content="Сохранить изменения" Click="BtnEditRoom_Click" Margin="0,0,0,5"/>
                        <Button Content="Удалить номер" Click="BtnDelRoom_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Управление услугами">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="dgServicesAdmin" AutoGenerateColumns="True" IsReadOnly="True" SelectionChanged="DgServicesAdmin_SelectionChanged" Margin="5"/>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Название услуги" FontWeight="Bold"/>
                        <TextBox x:Name="txtServName" Margin="0,5"/>

                        <TextBlock Text="Стоимость (руб)"/>
                        <TextBox x:Name="txtServPrice" Margin="0,5"/>

                        
                        <Button Content="Добавить услугу" Click="BtnAddServ_Click" Margin="0,15,0,5"/>
                        <Button Content="Сохранить изменения" Click="BtnEditServ_Click" Margin="0,0,0,5"/>
                        <Button Content="Удалить услугу" Click="BtnDelServ_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>