<Window x:Class="Zakharov_hotel.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="370" Width="400" WindowStartupLocation="CenterScreen" Background="{StaticResource BaseColor}" FocusManager.FocusedElement="{Binding ElementName=txtLogin}">
    <TabControl Background="{StaticResource BaseColor}">
        <TabItem Header="Вход">
            <StackPanel Margin="30">
                <TextBlock Text="Логин"/>
                <TextBox x:Name="txtLogin" Margin="0,5,0,10" Height="25" />
                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="txtPass" Margin="0,5,0,20" Height="25" Background="{StaticResource SurfaceColor}"/>
                <Button Content="Войти" Click="BtnLogin_Click" Height="35" />
            </StackPanel>
        </TabItem>
        <TabItem Header="Регистрация" FocusManager.FocusedElement="{Binding ElementName=txtRegLogin}">
            <StackPanel Margin="30">
                <TextBlock Text="Логин"/>
                <TextBox x:Name="txtRegLogin" Margin="0,5,0,10"/>
                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="txtRegPass" Margin="0,5,0,10"/>
                <TextBlock Text="ФИО"/>
                <TextBox x:Name="txtRegName" Margin="0,5,0,20"/>
                <Button Content="Создать аккаунт" Click="BtnRegister_Click" Height="35" Cursor="Hand"/>
            </StackPanel>
        </TabItem>
    </TabControl>

</Window>